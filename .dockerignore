# Keep the e2e-install build context small. install.sh will recreate
# node_modules and .next inside the container, so shipping them in the image
# would just double the disk footprint and cache mismatches.
node_modules
.next
.git/lfs
.git/logs
test-results
playwright-report
local-data
data/config.json
data/kv.json
data/.session-secret
data/webapps
data/code-projects
e2e-install/.env.test
e2e-install/test-results
e2e-install/playwright-report
**/*.log
.DS_Store

# Host .env files leak host-specific paths (CLAWBOX_HOME=/home/nexus0,
# FILES_ROOT=/home/nexus0, etc.) and credentials into the container, where
# systemd loads them via EnvironmentFile and Next.js then tries to mkdir
# under non-existent host paths. Always rebuild .env from .env.example
# inside the container.
.env
.env.local
.env.development
.env.production
.env.test
