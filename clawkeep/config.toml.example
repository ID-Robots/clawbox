# /etc/clawkeep/config.toml
#
# Copy this to /etc/clawkeep/config.toml and edit. Fields are documented
# in section 7 of the design doc (clawkeep-plan.md).

# Portal endpoint. Change once the canonical domain migrates.
server = "https://openclawhardware.dev"

# How often the systemd timer fires. Keep in sync with the timer unit.
schedule = "daily"  # daily | weekly | manual

# clawkeep delegates "what to back up" to `openclaw backup create` —
# it captures OpenClaw state, config, credentials, sessions, and
# (optionally) workspaces. See https://docs.openclaw.ai/cli/backup.
[openclaw]
binary = "openclaw"          # absolute path or PATH-resolvable name
include_workspace = true     # set false to skip ~/.openclaw/workspace
only_config = false          # set true to back up only the active JSON config file
verify = true                # run `openclaw backup verify` after writing
output_dir = ""              # blank → tmpdir per run (cleaned up on exit)

[heartbeat]
idle_interval_hours = 24
