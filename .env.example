ALLOW_INSECURE_CONTROL_UI=true

# Google Gemini CLI OAuth credentials (public installed-app client)
# These are set automatically by install.sh — no manual config needed.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Optional: enables ClawBox AI as an automatic OpenClaw fallback model.
# CLAWBOX_AI_API_KEY=

# Optional: connect the llama.cpp local provider to a running llama-server.
# LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
# LLAMACPP_MODEL=gemma4-e2b-it-q4_0
# LLAMACPP_HF_REPO=gguf-org/gemma-4-e2b-it-gguf
# LLAMACPP_HF_FILE=gemma-4-e2b-it-edited-q4_0.gguf
# LLAMACPP_BIN=/usr/local/bin/llama-server
# LLAMACPP_CONTEXT_WINDOW=131072
# LLAMACPP_CACHE_TYPE_K=q4_0
# LLAMACPP_CACHE_TYPE_V=q4_0
# Optional override for OpenClaw's output budget. If unset, ClawBox uses the
# full llama.cpp context window instead of a smaller app-level cap.
# LLAMACPP_MAX_TOKENS=131072
